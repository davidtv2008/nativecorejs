{
  "name": "nativecorejs",
  "version": "0.1.0",
  "description": "NativeCore framework runtime primitives and utilities",
  "keywords": [
    "nativecore",
    "nativecorejs",
    "web-components",
    "signals",
    "spa"
  ],
  "homepage": "https://github.com/davidtv2008/nativecorejs#readme",
  "bugs": {
    "url": "https://github.com/davidtv2008/nativecorejs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidtv2008/nativecorejs.git"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./components": {
      "types": "./dist/src/components/index.d.ts",
      "import": "./dist/src/components/index.js"
    },
    "./styles/base.css": "./src/styles/base.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
